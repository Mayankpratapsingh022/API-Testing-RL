# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# =====================================================================
# REQUIRED for inference.py (per OpenEnv submission spec)
# =====================================================================

# OpenAI-compatible LLM endpoint. Defaults to the HuggingFace router.
API_BASE_URL=https://router.huggingface.co/v1

# Model identifier the OpenAI client will request.
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# HuggingFace Hub token / API key — used for both inference and Hub push.
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================================
# OPTIONAL for inference.py — pick ONE env transport (default: in-process)
# =====================================================================

# Use a built docker image (matches the OpenEnv sample script)
# IMAGE_NAME=api-testing-env:latest

# Or connect to an already-running env server (local or HF Space)
# ENV_BASE_URL=http://localhost:8000
# ENV_BASE_URL=https://your-username-api-testing-env.hf.space

# Optional inference tuning
# INFERENCE_TASKS=basic_validation,edge_cases,security_workflows
# INFERENCE_MAX_STEPS=25
# INFERENCE_TEMPERATURE=0.4
# INFERENCE_MAX_TOKENS=3072

# =====================================================================
# OPTIONAL for GRPO training (training/grpo.py)
# =====================================================================

# Weights & Biases — required for --use-wandb
# Get your key at: https://wandb.ai/authorize
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: set W&B defaults
# WANDB_PROJECT=api-testing-grpo
# WANDB_ENTITY=your-team-name
