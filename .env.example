# Copy this file to .env and fill in your token:
#   cp .env.example .env
#
# .env is gitignored. .env.example is committed.
#
# IMPORTANT: Judges DO NOT use this file. They set HF_TOKEN themselves
# in their evaluation environment. This file is for LOCAL development only.
# inference.py auto-loads .env via python-dotenv when present.

# =====================================================================
# REQUIRED — your HuggingFace token
# =====================================================================
# Get one at: https://huggingface.co/settings/tokens
#   - Token type: "Read" or "Fine-grained"
#   - Permission: "Make calls to Inference Providers"
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================================
# OPTIONAL — only set if you want to override the defaults
# =====================================================================
# All these have sensible defaults baked into inference.py / training/grpo.py

# LLM endpoint (default: HuggingFace router — same for everyone)
# API_BASE_URL=https://router.huggingface.co/v1

# Model the agent uses (default: Qwen/Qwen2.5-72B-Instruct)
# MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Inference tuning
# INFERENCE_TEMPERATURE=0.4
# INFERENCE_MAX_TOKENS=4096
# INFERENCE_TASKS=basic_validation,edge_cases,security_workflows
# INFERENCE_MAX_STEPS=25

# Environment transport (default: in-process)
# IMAGE_NAME=api-testing-env:latest                            # use local docker
# ENV_BASE_URL=https://your-user-api-testing-env.hf.space      # use deployed HF Space

# =====================================================================
# OPTIONAL — only for GRPO training (training/grpo.py)
# =====================================================================
# WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WANDB_PROJECT=api-testing-grpo
